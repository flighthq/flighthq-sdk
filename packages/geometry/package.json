    },
    "./matrix4": {
      "types": "./dist/matrix4.d.ts",
      "default": "./dist/matrix4.js"
    },
    "./matrix4Pool": {
      "types": "./dist/matrix4Pool.d.ts",
      "default": "./dist/matrix4Pool.js"
    },
    "./rectangle": {
      "types": "./dist/rectangle.d.ts",
      "default": "./dist/rectangle.js"
    },
    "./rectanglePool": {
      "types": "./dist/rectanglePool.d.ts",
      "default": "./dist/rectanglePool.js"
