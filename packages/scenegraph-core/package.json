{
  "name": "@flighthq/scenegraph-core",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./boundsRect": {
      "types": "./dist/boundsRect.d.ts",
      "default": "./dist/boundsRect.js"
    },
    "./graphNode": {
      "types": "./dist/graphNode.d.ts",
      "default": "./dist/graphNode.js"
    },
    "./hasBoundsRect": {
      "types": "./dist/hasBoundsRect.d.ts",
      "default": "./dist/hasBoundsRect.js"
    },
    "./hasBoundsRectAndTransform2d": {
      "types": "./dist/hasBoundsRectAndTransform2d.d.ts",
      "default": "./dist/hasBoundsRectAndTransform2d.js"
    },
    "./hasTransform2d": {
      "types": "./dist/hasTransform2d.d.ts",
      "default": "./dist/hasTransform2d.js"
    },
    "./hierarchy": {
      "types": "./dist/hierarchy.d.ts",
      "default": "./dist/hierarchy.js"
    },
    "./revision": {
      "types": "./dist/revision.d.ts",
      "default": "./dist/revision.js"
    },
    "./transform2d": {
      "types": "./dist/transform2d.d.ts",
      "default": "./dist/transform2d.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/foundation": "*",
    "@flighthq/geometry": "*",
    "@flighthq/signals": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Base scene graph: transform hierarchy, bounds, appearance traits, child management"
}
