{
  "name": "@flighthq/render-canvas",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./background": {
      "types": "./dist/canvasBackground.d.ts",
      "default": "./dist/canvasBackground.js"
    },
    "./bitmap": {
      "types": "./dist/canvasBitmap.d.ts",
      "default": "./dist/canvasBitmap.js"
    },
    "./cacheAsBitmap": {
      "types": "./dist/canvasCacheAsBitmap.d.ts",
      "default": "./dist/canvasCacheAsBitmap.js"
    },
    "./clipRect": {
      "types": "./dist/canvasClipRect.d.ts",
      "default": "./dist/canvasClipRect.js"
    },
    "./displayObject": {
      "types": "./dist/canvasDisplayObject.d.ts",
      "default": "./dist/canvasDisplayObject.js"
    },
    "./mask": {
      "types": "./dist/canvasMask.d.ts",
      "default": "./dist/canvasMask.js"
    },
    "./materials": {
      "types": "./dist/canvasMaterials.d.ts",
      "default": "./dist/canvasMaterials.js"
    },
    "./quadBatch": {
      "types": "./dist/canvasQuadBatch.d.ts",
      "default": "./dist/canvasQuadBatch.js"
    },
    "./renderState": {
      "types": "./dist/canvasRendererState.d.ts",
      "default": "./dist/canvasRendererState.js"
    },
    "./transform": {
      "types": "./dist/canvasTransform.d.ts",
      "default": "./dist/canvasTransform.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/geometry": "*",
    "@flighthq/render-core": "*",
    "@flighthq/scenegraph-display": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Canvas 2D renderer implementation"
}
