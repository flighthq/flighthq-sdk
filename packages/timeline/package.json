{
  "name": "@flighthq/timeline",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./movieClip": {
      "types": "./dist/movieClip.d.ts",
      "default": "./dist/movieClip.js"
    },
    "./timeline": {
      "types": "./dist/timeline.d.ts",
      "default": "./dist/timeline.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@flighthq/scenegraph-display": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Timeline-based animation sequencing"
}
