{
  "name": "@flighthq/assets",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./imageSource": {
      "types": "./dist/imageSource.d.ts",
      "default": "./dist/imageSource.js"
    },
    "./spritesheet": {
      "types": "./dist/spritesheet.d.ts",
      "default": "./dist/spritesheet.js"
    },
    "./textureAtlas": {
      "types": "./dist/textureAtlas.d.ts",
      "default": "./dist/textureAtlas.js"
    },
    "./tileset": {
      "types": "./dist/tileset.d.ts",
      "default": "./dist/tileset.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/entity": "*",
    "@flighthq/geometry": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Asset types and utilities: image sources, texture atlases, tilesets"
}
