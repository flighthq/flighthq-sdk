{
  "name": "@flighthq/interaction",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./displayHitTests": {
      "types": "./dist/displayHitTests.d.ts",
      "default": "./dist/displayHitTests.js"
    },
    "./hitTests": {
      "types": "./dist/hitTests.d.ts",
      "default": "./dist/hitTests.js"
    },
    "./interactionManager": {
      "types": "./dist/interactionManager.d.ts",
      "default": "./dist/interactionManager.js"
    },
    "./spriteHitTests": {
      "types": "./dist/spriteHitTests.d.ts",
      "default": "./dist/spriteHitTests.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest --config vitest.config.ts",
    "test:watch": "vitest --watch --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@flighthq/geometry": "*",
    "@flighthq/scenegraph-core": "*",
    "@flighthq/scenegraph-display": "*",
    "@flighthq/signals": "*",
    "@flighthq/types": "*",
    "@flighthq/scenegraph-world": "*"
  },
  "devDependencies": {
    "@flighthq/scenegraph-sprite": "*",
    "typescript": "^5.3.0"
  },
  "description": "Hit testing: point-in-node tests and object overlap detection"
}
