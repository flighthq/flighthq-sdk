{
  "name": "@flighthq/engine",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/animation-spritesheet": "*",
    "@flighthq/foundation": "*",
    "@flighthq/geometry": "*",
    "@flighthq/materials": "*",
    "@flighthq/render-core": "*",
    "@flighthq/render-canvas": "*",
    "@flighthq/scene-graph-core": "*",
    "@flighthq/scene-graph-display": "*",
    "@flighthq/scene-graph-sprite": "*",
    "@flighthq/scene-graph-world": "*",
    "@flighthq/signals": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Single entry point re-exporting all packages"
}
