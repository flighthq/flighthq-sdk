{
  "name": "@flighthq/engine",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@flighthq/assets": "*",
    "@flighthq/foundation": "*",
    "@flighthq/geometry": "*",
    "@flighthq/materials": "*",
    "@flighthq/render-core": "*",
    "@flighthq/render-canvas": "*",
    "@flighthq/render-canvas-shape": "*",
    "@flighthq/shape": "*",
    "@flighthq/scenegraph-core": "*",
    "@flighthq/scenegraph-display": "*",
    "@flighthq/scenegraph-sprite": "*",
    "@flighthq/scenegraph-world": "*",
    "@flighthq/signals": "*",
    "@flighthq/spritesheet": "*",
    "@flighthq/timeline": "*",
    "@flighthq/timeline-spritesheet": "*",
    "@flighthq/tween": "*",
    "@flighthq/tween-easing": "*",
    "@flighthq/types": "*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "description": "Single entry point re-exporting all packages"
}
